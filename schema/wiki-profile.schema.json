{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Profile",
  "type": "object",
  "required": ["name", "domain", "persona", "focus_areas", "pinned_pages"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "persona": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "focus_areas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "impact_lenses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "description"],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "pipeline_stages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "industries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pinned_pages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_policy": {
      "type": "object"
    }
  }
}

